# Copy this file to ".env" and fill real values. .env is gitignored.

# --- Database ---
# Local dev uses SQLite (a single file). Later we switch to Postgres on Railway.
DATABASE_URL=sqlite:///./blogger.db

# --- JWT ---
# Secret used to sign tokens. Generate a real one, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# --- CORS ---
# Explicit list of allowed frontend origins (comma-separated). NEVER "*" with cookies.
CORS_ORIGINS=http://localhost:5173

# --- Cookie ---
# In production (HTTPS) these must be: secure=true, samesite=none.
# For local HTTP dev we relax them (secure=false, samesite=lax) - explained when we wire it.
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
