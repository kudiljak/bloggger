# Copy this file to ".env" and fill real values. .env is gitignored.

# --- Database ---
# Local dev uses SQLite (a single file). Production uses Postgres (Cloud SQL):
#   DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL=sqlite:///./blogger.db

# --- Checkpointer (LangGraph graph state) ---
# Empty = in-memory MemorySaver (local dev). Production = Redis Cloud connection string:
#   REDIS_URL=redis://default:PASSWORD@HOST:PORT
# (Redis Cloud / Redis Enterprise, which has RediSearch; NOT GCP Memorystore.)
REDIS_URL=

# --- JWT ---
# Secret used to sign tokens. Generate a real one, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# --- CORS ---
# Explicit list of allowed frontend origins (comma-separated). NEVER "*" with cookies.
CORS_ORIGINS=http://localhost:5173

# --- Cookie ---
# In production (HTTPS) these must be: secure=true, samesite=none.
# For local HTTP dev we relax them (secure=false, samesite=lax) - explained when we wire it.
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# --- Logging ---
LOG_LEVEL=INFO
# Set to true to see every SQL statement (noisy; handy when learning/debugging).
SQL_ECHO=false

# --- LLM ---
# Get a key at console.anthropic.com. Leave empty while testing with a fake LLM.
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-4-6
MAX_REVISIONS=3
